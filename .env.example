RUN_MODE=development

# Config override example
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=3000
APP__REDIS__URL=redis://localhost:16379
APP__REDIS__MAX_CONNECTIONS=10
APP__CACHE__DEFAULT_TTL_SECS=300
APP__RUNTIME__CACHE_PROVIDER=memory
APP__RUNTIME__LBS_PROVIDER=noop

