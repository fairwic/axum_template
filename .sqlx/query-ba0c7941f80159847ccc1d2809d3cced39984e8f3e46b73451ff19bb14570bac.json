  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, store_id, category_id, title, subtitle, cover_image, images, price,\n                   original_price, stock, status, tags, created_at, updated_at\n            FROM products\n            WHERE store_id = $1 AND category_id = $2\n            ORDER BY created_at DESC\n            LIMIT $3 OFFSET $4\n            ",
